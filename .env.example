# Database
DATABASE_URL=postgresql://kalit:kalit@localhost:5432/kalit_marketing?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Supervisor (set to "true" to start BullMQ workers on dev)
START_SUPERVISOR=false

# Auth
AUTH_SECRET=change-me-in-production
AUTH_DISABLED=false

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Mock mode (set to true for development without real API keys)
MOCK_ADAPTERS=true

# ─── Ad Platforms ───
META_APP_ID=
META_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
X_ADS_API_KEY=
X_ADS_API_SECRET=
X_ADS_BEARER_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Analytics ───
GOOGLE_ANALYTICS_CREDENTIALS=     # base64-encoded service account JSON
POSTHOG_HOST=https://app.posthog.com
MIXPANEL_API_SECRET=

# ─── Revenue ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email ───
RESEND_API_KEY=
SENDGRID_API_KEY=

# ─── CRM ───
HUBSPOT_ACCESS_TOKEN=

# ─── Content Generation ───
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
IMAGE_GEN_PROVIDER=replicate    # or "openai"

# ─── Encryption ───
ENCRYPTION_KEY=                 # 32-byte hex key for credential encryption
